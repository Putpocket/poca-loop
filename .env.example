APP_NAME=poca-loop
ENVIRONMENT=local
SECRET_KEY=example-change-this-to-a-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=60
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8000

# LAN browser access example:
# BACKEND_CORS_ORIGINS=http://localhost:5173,http://192.168.10.203:5173

# Local venv development: use this when PostgreSQL/Redis run on the host.
DATABASE_URL=postgresql+psycopg://pocaloop:pocaloop_example_password@localhost:5432/pocaloop
REDIS_URL=redis://localhost:6379/0

# Docker Compose deployment: use these inside containers instead.
# docker-compose.yml uses COMPOSE_DATABASE_URL and COMPOSE_REDIS_URL so local venv values above can stay unchanged.
COMPOSE_DATABASE_URL=postgresql+psycopg://pocaloop:pocaloop_example_password@db:5432/pocaloop
COMPOSE_REDIS_URL=redis://redis:6379/0

# Docker Compose published ports.
API_PORT=8000
FRONTEND_PORT=8080
POSTGRES_PORT=5432
REDIS_PORT=6379

# Empty means the production frontend calls API routes through the same origin Nginx proxy.
FRONTEND_API_BASE_URL=

POSTGRES_DB=pocaloop
POSTGRES_USER=pocaloop
POSTGRES_PASSWORD=pocaloop_example_password
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=example-change-this-admin-password
